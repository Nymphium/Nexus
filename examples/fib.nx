import { print } from nxlib/stdlib/stdio.nx
import { i64_to_string } from nxlib/stdlib/string.nx

let fib = fn (n: i64) -> i64 do
  if n == 0 then
    return 0
  endif
  if n == 1 then
    return 1
  endif
  let a = fib(n: n - 1)
  let b = fib(n: n - 2)
  return a + b
endfn

let main = fn () ->  unit effect { Console } do
  let v = fib(n: 30)
  let val = i64_to_string(val: v)
  print(val: val)
  return ()
endfn
