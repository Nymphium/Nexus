{
  "name": "tree-sitter-nexus",
  "version": "0.1.0",
  "description": "Tree-sitter grammar for the Nexus programming language",
  "main": "bindings/node",
  "keywords": [
    "tree-sitter",
    "nexus",
    "parser",
    "grammar"
  ],
  "files": [
    "grammar.js",
    "tree-sitter.json",
    "src/",
    "queries/",
    "bindings/"
  ],
  "dependencies": {
    "node-addon-api": "^7.0.0",
    "node-gyp-build": "^4.5.0"
  },
  "devDependencies": {
    "tree-sitter-cli": "^0.26.0"
  },
  "scripts": {
    "build": "tree-sitter generate && node-gyp rebuild",
    "generate": "tree-sitter generate",
    "test": "tree-sitter test"
  },
  "tree-sitter": [
    {
      "scope": "source.nexus",
      "file-types": ["nx"],
      "highlights": "queries/highlights.scm",
      "locals": "queries/locals.scm"
    }
  ]
}
