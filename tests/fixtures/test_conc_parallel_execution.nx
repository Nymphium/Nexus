
    let main = fn () -> unit do
        let %arr = [| 0, 0 |]
        conc do
            task t1 do
                let lock = &%arr
                lock[0] <- 1
            end
            task t2 do
                let lock = &%arr
                lock[1] <- 2
            end
        end

        let lock = &%arr
        let v1 = lock[0]
        let v2 = lock[1]
        match %arr do case _ -> () end
        return ()
    end
    